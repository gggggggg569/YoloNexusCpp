    <VcpkgRuntimeDir>$(YoloVcpkgInstalledDir)$(VcpkgTriplet)\bin</VcpkgRuntimeDir>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <WarningLevel>Level4</WarningLevel>
      <LanguageStandard>stdcpp20</LanguageStandard>
      <ConformanceMode>true</ConformanceMode>
      <AdditionalOptions>/utf-8 %(AdditionalOptions)</AdditionalOptions>
      <DisableSpecificWarnings>4864;%(DisableSpecificWarnings)</DisableSpecificWarnings>
      <PreprocessorDefinitions>UNICODE;_UNICODE;ORT_API_MANUAL_INIT;_CRT_SECURE_NO_WARNINGS;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <AdditionalIncludeDirectories>$(ProjectDir)src;$(ProjectDir)src\app;$(YoloVcpkgInstalledDir)$(VcpkgTriplet)\include;$(YoloVcpkgInstalledDir)$(VcpkgTriplet)\include\opencv4;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ClCompile>
    <Link>
      <SubSystem>Console</SubSystem>
      <AdditionalLibraryDirectories>$(YoloVcpkgInstalledDir)$(VcpkgTriplet)\lib;%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <AdditionalDependencies>d3d11.lib;dxgi.lib;d3dcompiler.lib;gdi32.lib;user32.lib;ole32.lib;strmiids.lib;winmm.lib;pdh.lib;psapi.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
    <PostBuildEvent>
      <Command>copy /Y "$(VcpkgRuntimeDir)\*.dll" "$(TargetDir)" &gt;nul
if not exist "$(TargetDir)runtimes\directml" mkdir "$(TargetDir)runtimes\directml"
copy /Y "$(VcpkgRuntimeDir)\onnxruntime.dll" "$(TargetDir)runtimes\directml\onnxruntime.dll" &gt;nul
copy /Y "$(VcpkgRuntimeDir)\onnxruntime_providers_shared.dll" "$(TargetDir)runtimes\directml\onnxruntime_providers_shared.dll" &gt;nul
copy /Y "$(VcpkgRuntimeDir)\DirectML.dll" "$(TargetDir)runtimes\directml\DirectML.dll" &gt;nul
copy /Y "$(ProjectDir)config.txt" "$(TargetDir)config.txt" &gt;nul
copy /Y "$(ProjectDir)best4k.onnx" "$(TargetDir)best4k.onnx" &gt;nul</Command>
    </PostBuildEvent>
  </ItemDefinitionGroup>

  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <ClCompile>
      <Optimization>Disabled</Optimization>
      <RuntimeLibrary>MultiThreadedDebugDLL</RuntimeLibrary>
    </ClCompile>
    <Link>
      <AdditionalLibraryDirectories>$(YoloVcpkgInstalledDir)$(VcpkgTriplet)\debug\lib;%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <AdditionalDependencies>opencv_core4d.lib;opencv_imgproc4d.lib;opencv_dnn4d.lib;opencv_videoio4d.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <ClCompile>
      <Optimization>MaxSpeed</Optimization>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <IntrinsicFunctions>true</IntrinsicFunctions>
      <RuntimeLibrary>MultiThreadedDLL</RuntimeLibrary>
    </ClCompile>
    <Link>
      <EnableCOMDATFolding>true</EnableCOMDATFolding>
      <OptimizeReferences>true</OptimizeReferences>
      <AdditionalDependencies>opencv_core4.lib;opencv_imgproc4.lib;opencv_dnn4.lib;opencv_videoio4.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>

